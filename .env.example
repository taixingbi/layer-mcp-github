# Copy to .env (never commit .env)
GITHUB_TOKEN=
GITHUB_OWNER=your-github-user-or-org

# LLM gateway — POST {LLM_GATEWAY_BASE_URL}/v1/chat/completions
LLM_GATEWAY_BASE_URL=http://192.168.86.179:30180
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# Cap completion length for ask_repo answers (~120 words at 384; raise if answers truncate)
LLM_MAX_TOKENS=384
LLM_TEMPERATURE=0.5
# LLM_FOLLOW_UP_MAX_TOKENS=256
# MCP tool defaults (optional; tools can pass ids per call — see docs/schema.md)
# LLM_CONVERSATION_ID=conv_github_001
# LLM_REQUEST_ID=request-id-1
# LLM_SESSION_ID=session-id-1
# LLM_TRACE_ID=trace-id-1
# LLM_API_KEY=

# MCP streamable-http (python -m app.main --http or Docker)
HTTP_HOST=127.0.0.1
HTTP_PORT=8000

# Ops /version: default from pyproject.toml [project].version (override at deploy time)
# VERSION=1.0.0
